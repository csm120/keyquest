#!/bin/sh
old_ref="$1"
new_ref="$2"
is_branch_checkout="$3"

if [ "$is_branch_checkout" != "1" ]; then
  exit 0
fi

changed_paths=$(git diff --name-only "$old_ref" "$new_ref")
powershell -NoProfile -ExecutionPolicy Bypass -File "tools/dev/refresh_dist_if_needed.ps1" -Trigger post-checkout -ChangedPaths $changed_paths
